#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${APP_DATA_DIR}/config"
CONFIG_FILE="${CONFIG_DIR}/settings.json"
ENV_FILE="${CONFIG_DIR}/worker.env"
TOKEN_DIR="${APP_DATA_DIR}/garminconnect"

mkdir -p "${CONFIG_DIR}" "${TOKEN_DIR}"

if [ ! -f "${CONFIG_FILE}" ]; then
  cat > "${CONFIG_FILE}" <<'EOF'
{
  "garmin_email": "",
  "garmin_base64_password": "",
  "garmin_is_cn": false,
  "influx_host": "influxdb_influxdb_1",
  "influx_port": "8086",
  "influx_username": "admin",
  "influx_password": "",
  "influx_database": "GarminStats",
  "update_interval_seconds": "300",
  "user_timezone": "",
  "log_level": "INFO",
  "fetch_selection": ""
}
EOF
fi

if [ ! -f "${ENV_FILE}" ]; then
  cat > "${ENV_FILE}" <<'EOF'
GARMINCONNECT_EMAIL=
GARMINCONNECT_BASE64_PASSWORD=
GARMINCONNECT_IS_CN=False
INFLUXDB_HOST=influxdb_influxdb_1
INFLUXDB_PORT=8086
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=
INFLUXDB_DATABASE=GarminStats
UPDATE_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
EOF
fi

chown -R 1000:1000 "${APP_DATA_DIR}"
